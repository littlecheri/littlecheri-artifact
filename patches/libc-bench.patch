+
+#define INIT_MB_STRUCT void **_p = calloc(ARRAY_SIZE, sizeof(void *));\
+	bool *_a = calloc(ARRAY_SIZE, sizeof(bool));\
+	malloc_bench_struct s = {_p, _a};
+#define RELEASE_MB_STRUCT free(_p); free(_a);
+
+void __attribute__((always_inline)) inline bench_malloc(malloc_bench_struct *s, size_t size, size_t off)
+{
+	s->a[off] = true;
+	s->p[off] = MAYBE_UNINIT_WRAPPER(malloc)(size);
+}
+
+void __attribute__((always_inline)) inline bench_free(malloc_bench_struct *s, size_t off)
+{
+	MAYBE_UNINIT_WRAPPER(free)(s->p[off]);
+	s->a[off] = false;
+}
+
+void __attribute__((always_inline)) inline malloc_recover_memory(malloc_bench_struct *s, size_t array_size)
+{
+	for (size_t i=0; i < array_size; i++)
+		if (s->a[i]) 
+			MAYBE_UNINIT_WRAPPER(free)(s->p[i]);
+}
 
