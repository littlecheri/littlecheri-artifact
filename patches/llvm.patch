+  //     BuildMI(MBB, MBBI, DL, TII->get(RISCV::CLC_128), FrameCapReg)
+  //       .addReg(IDC).addImm(-16);
+  // }
+
+  // remove expanded pseudo-instruction
+  MI.eraseFromParent();
+  return BB;
