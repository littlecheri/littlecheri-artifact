+  [RISCV_SYS_READ] = "SYS_READ",
+  [RISCV_SYS_ISTTY] = "SYS_ISTTY",
+  [RISCV_SYS_SEEK] = "SYS_SEEK",
+  [RISCV_SYS_FLEN] = "SYS_FLEN",
