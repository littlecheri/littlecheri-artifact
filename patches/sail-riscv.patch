+#define SEMIHOST_MAX_PARAM_COUNT 4
+void read_params(uint64_t* host_param_array, mach_bits guest_param_ptr,
+                 int param_count)
+{
+  int xlen_bytes = zxlen_val / 8;
+  for (int param_i = 0; param_i < param_count; param_i++)
+  {
+    sbits guest_param = fast_read_ram(xlen_bytes, guest_param_ptr + param_i*xlen_bytes);
+    host_param_array[param_i] = guest_param.bits;
+  }
+}
+
+void read_null_terminated_string(char* host_string, uint64_t guest_string_ptr,
+                                 uint64_t string_length)
+{
+  assert(host_string != NULL && "Got NULL instead of host_string pointer!");
+  assert(string_length > 0 && "Trying to read empty string!");
+  for (int char_i = 0; char_i < string_length; char_i++)
+  {
+    host_string[char_i] = (char)read_mem(guest_string_ptr + char_i);
+    if (!host_string[char_i]) return;
+  }
+  // null terminate the string ourselves if the buffer ran out of space
+  host_string[string_length - 1] = 0;
+}
+
+void read_n_bytes(char* host_buffer, uint64_t guest_buffer_ptr, uint64_t n)
+{
+  assert(host_buffer != NULL && "Got NULL instead of host_buffer pointer!");
+  assert(n > 0 && "Trying to read 0 bytes!");
+  for (int byte_i = 0; byte_i < n; byte_i++)
+  {
+    host_buffer[byte_i] = (char)read_mem(guest_buffer_ptr + byte_i);
+  }
+}
+
+void write_n_bytes(char* host_buffer, uint64_t guest_buffer_ptr, uint64_t n)
+{
+  assert(host_buffer != NULL && "Got NULL instead of host_buffer pointer!");
+  assert(n > 0 && "Trying to write 0 bytes!");
+  for (int byte_i = 0; byte_i < n; byte_i++)
+  {
+    write_mem(guest_buffer_ptr + byte_i, host_buffer[byte_i]);
+  }
+}
+
+void write_unsigned_int(uint64_t value, uint64_t guest_buffer_ptr, uint64_t offset)
+{
+  char* value_as_bytes = (void*)&value;
+  for (int byte_i = 0; byte_i < sizeof(value); byte_i++)
+  {
+    write_mem(guest_buffer_ptr + offset + byte_i, value_as_bytes[byte_i]);
+  }
+}
+
+mach_bits plat_handle_semihosting(uint64_t op_number, uint64_t parameter_ptr)
+{
+  riscv_semihosting_op op = op_number;
+  print_semihost_syscall("Op: %s (0x%02X)", syscall_to_string(op), op);
+  uint64_t params[SEMIHOST_MAX_PARAM_COUNT];
+  uint64_t return_value = 0;
+  SemihostGuestFD guest_fd;
+  uint64_t guest_buffer_ptr;
+  switch (op) {
+    case RISCV_SYS_OPEN:
+      read_params(params, parameter_ptr, 3);
+      int file_name_len = params[2] + 1; // parameter does not take null byte into account
+      char* file_name = (char*) malloc(file_name_len * sizeof(char));
+      read_null_terminated_string(file_name, params[0], file_name_len);
+      return_value = plat_semihost_open_impl(file_name, params[1], file_name_len);
+      free(file_name);
+      break;
+    case RISCV_SYS_EXIT:
+      assert(zxlen_val == 64 && "Not supported yet on 32 bit");
+      read_params(params, parameter_ptr, 2);
+      int exception_code = params[0];
+      int exception_subcode = params[1];
+      plat_semihost_exit_impl(exception_code, exception_subcode);
+      break;
+    case RISCV_SYS_FLEN:
+      read_params(params, parameter_ptr, 1);
+      guest_fd = params[0];
+      return_value = plat_semihost_flen_impl(guest_fd);
+      break;
+    case RISCV_SYS_ISTTY:
+      read_params(params, parameter_ptr, 1);
+      guest_fd = params[0];
+      return_value = plat_semihost_istty_impl(guest_fd);
+      break;
+    case RISCV_SYS_WRITE:
+      read_params(params, parameter_ptr, 3);
+      guest_fd = params[0];
+      guest_buffer_ptr = params[1];
+      int n_to_write = params[2];
+      char* write_buffer = (char*) malloc(n_to_write * sizeof(char));
+      read_n_bytes(write_buffer, guest_buffer_ptr, n_to_write);
+      return_value = plat_semihost_write_impl(guest_fd, write_buffer, n_to_write);
+      free(write_buffer);
+      break;
+    case RISCV_SYS_READ:
+      read_params(params, parameter_ptr, 3);
+      guest_fd = params[0];
+      guest_buffer_ptr = params[1];
+      int n_to_read = params[2];
+      char* read_buffer = (char*) malloc(n_to_read * sizeof(char));
+      return_value = plat_semihost_read_impl(guest_fd, read_buffer, n_to_read);
+      write_n_bytes(read_buffer, guest_buffer_ptr, n_to_read);
+      break;
+    case RISCV_SYS_ERRNO:
+      return_value = plat_semihost_errno_impl();
+      break;
+    case RISCV_SYS_SEEK:
+      read_params(params, parameter_ptr, 2);
+      guest_fd = params[0];
+      int offset = params[1];
+      return_value = plat_semihost_seek_impl(guest_fd, offset);
+      break;
+    case RISCV_SYS_CLOSE:
+      read_params(params, parameter_ptr, 1);
+      guest_fd = params[0];
+      return_value = plat_semihost_close_impl(guest_fd);
+      break;
+    case RISCV_SYS_TIME:
+      return_value = plat_semihost_time_impl();
+      break;
+    case RISCV_SYS_GET_CMDLINE:
+      read_params(params, parameter_ptr, 2);
+      guest_buffer_ptr = params[0];
+      int guest_buffer_len = params[1];
+      char *arg_buffer = malloc(guest_buffer_len * sizeof(guest_buffer_len));
+      return_value = plat_semihost_get_cmdline_impl(arg_buffer, guest_buffer_len);
+      if (return_value == -1) break; // negative return indicates error
+      if (return_value != 0) // write args to guest if not empty
+        write_n_bytes(arg_buffer, guest_buffer_ptr, return_value);
+      write_unsigned_int(return_value, parameter_ptr, zxlen_val/8);
+      return_value = 0;
+      break;
+    default:
+      print_semihost_syscall("Unknown operation!");
+      break;
+  }
+  if (return_value < 0) {
+    print_semihost_failure(return_value);
+  } else {
+    print_semihost_syscall("Success! Result: %d", return_value);
+  }
+  return return_value;
+}
