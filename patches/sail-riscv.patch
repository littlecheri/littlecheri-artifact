@@ -743,16 +743,68 @@ function clause execute SRET() = {
 mapping clause assembly = SRET() <-> "sret"
 
 /* ****************************************************************** */
+
+val is_ebreak_for_semihosting : xlenbits -> option(bool)
+function is_ebreak_for_semihosting(current_pc) = {
+  /* Read instruction before and after current PC to check if they match the
+     NOPs specified in the semihosting spec.
+     TODO: add check filtering out address translation */
+  let pc_before = current_pc - 4;
+  let pc_after = current_pc + 4;
+  match mem_read(Execute(), pc_before, 4, false, false, false) {
+    MemException(_) => None(),
+    MemValue(inst_before) => {
+      if encdec(inst_before) == SHIFTIOP(0b01_1111, 0b00000, 0b00000, RISCV_SLLI) then
+        match mem_read(Execute(), pc_after, 4, false, false, false) {
+          MemException(_) => None(),
+          MemValue(inst_after) => {
+            if encdec(inst_after) == SHIFTIOP(0b00_0111, 0b00000, 0b00000, RISCV_SRAI) then Some(true)
+            else Some(false)
+          }
+        }
+      else Some(false)
+    }
+  }
+}
+
+val handle_semihosting : unit -> Retired effect { escape }
+function handle_semihosting() = {
+  let next_pc = get_next_pc() + 4;
+  match ext_control_check_pc(next_pc) {
+    Ext_ControlAddr_Error(e) => {
+      ext_handle_control_check_error(e);
+      RETIRE_FAIL
+    },
+    Ext_ControlAddr_OK(target) => {
+      set_next_pc(target);
+      let op_number = X(reg_name("a0"));
+      let parameter_ptr = X(reg_name("a1"));
+      let return_val = plat_handle_semihosting(op_number, parameter_ptr);
+      X(reg_name("a0")) = return_val;
+      RETIRE_SUCCESS
+    }
+  }
+}
+
 union clause ast = EBREAK : unit
 
 mapping clause encdec = EBREAK()
   <-> 0b000000000001 @ 0b00000 @ 0b000 @ 0b00000 @ 0b1110011
 
 function clause execute EBREAK() = {
-  handle_mem_exception(PC, E_Breakpoint());
-  RETIRE_FAIL
+  let is_semihosting_ebreak = if plat_enable_semihosting() then is_ebreak_for_semihosting(PC) else None();
+  match is_semihosting_ebreak {
+    Some(true) => {
+      handle_semihosting()
+    },
+    _ => {
+      handle_mem_exception(PC, E_Breakpoint());
+      RETIRE_FAIL
+    }
+  }
 }
 
+
 mapping clause assembly = EBREAK() <-> "ebreak"
 
 /* ****************************************************************** */
