+const char *syscall_to_string(riscv_semihosting_op op) {
+  return syscall_string[op];
+}
+
+int plat_semihost_open_impl(char* file_name, int semihost_mode, int file_name_len)
+{
+  print_semihost_syscall("\tPath: %s (len: %d)", file_name, file_name_len);
+  int open_mode = SEMIHOST_OPEN_MODE_MAPPING[semihost_mode];
+  print_semihost_syscall("\tMode: %s (Semihost: %d, Unix: 0x%03X)"
+  , SEMIHOST_OPEN_MODE_STRING[semihost_mode], semihost_mode, open_mode);
+  if (strncmp(file_name, ":semihosting-features", file_name_len) == 0)
+  {
+    assert(false && "TODO: implement semihosting feature reporting");
+  }
+  if (strncmp(file_name, ":tt", file_name_len) == 0)
+  {
+    if (open_mode & O_TRUNC) {
+      print_semihost_syscall("Giving stdout handle.");
+      return STDOUT_FILENO; // w, wb, w+ or w+b is stdout
+    } else if (open_mode & O_APPEND) {
+      print_semihost_syscall("Giving stderr handle.");
+      return STDERR_FILENO; // a, ab, a+ or a+b is stderr
+    } else {
+      print_semihost_syscall("Giving stdin handle.");
+      return STDIN_FILENO;
+    }
+  }
+
+  int host_fd = open(file_name, open_mode, 0644);
+  if (host_fd < 0) { // error case
+    guest_errno = errno;
+    return -1;
+  }
+  SemihostGuestFD guest_fd = allocate_host_fd_mapping(host_fd);
+  return guest_fd;
+}
+
+extern bool zhtif_done;
+extern uint64_t zhtif_exit_code;
+
+void plat_semihost_exit_impl(int exit_code, int exit_subcode)
+{
+  zhtif_done = true;
+  switch (exit_code) {
+    case ADP_Stopped_ApplicationExit:
+      print_semihost_syscall("Normal exit.");
+      zhtif_exit_code = exit_subcode;
+      break;
+    case ADP_Stopped_AddressException:
+      print_semihost_syscall("Exception occurred!");
+      zhtif_exit_code = exit_subcode;
+      break;
+    default:
+      print_semihost_syscall("Unexpected exit code: 0x%x", exit_code);
+      zhtif_exit_code = 42;
+  }
+  
+  print_semihost_syscall("Exiting with code %d", zhtif_exit_code);
+}
+
+bool semihost_fd_assertion_fail(char* debug_message)
+{
+  print_semihost_syscall(debug_message);
+  print_semihost_syscall("FD map dump (guest, host):");
+  for (int fd_i = 0; fd_i < MAX_FD_MAPPINGS; fd_i++) {
+    if (fd_map[fd_i].type != SemihostUnusedFD)
+      print_semihost_syscall("\t(%d,%d) Type: %s (%d)",
+        fd_i, fd_map[fd_i],
+        fd_map[fd_i].type == SemihostHostFD ? "Host" : "Other", fd_map[fd_i].type
+        );
+  }
+  return false;
+}
+
+int plat_semihost_flen_impl(SemihostGuestFD guest_fd)
+{
+  print_semihost_syscall("Getting file size for handle %d", guest_fd);
+  assert(fd_map[guest_fd].type == SemihostHostFD || semihost_fd_assertion_fail("Flen not supported on non host fd"));
+  int host_fd = fd_map[guest_fd].host_fd;
+  struct stat stat_result;
+  fstat(host_fd, &stat_result);
+  print_semihost_syscall("\tStat result: %ld", stat_result.st_size);
+  return stat_result.st_size;
+}
+
+int plat_semihost_istty_impl(SemihostGuestFD guest_fd)
+{
+  assert(fd_map[guest_fd].type == SemihostHostFD && "istty only supported for host fd");
+  bool istty = isatty(fd_map[guest_fd].host_fd);
+  print_semihost_syscall("\tFile handle %d %s a TTY.", 
+    guest_fd,
+    istty ? "is" : "is not");
+  return istty;
+}
+
+int plat_semihost_write_impl(SemihostGuestFD guest_fd, char* buffer, int n)
+{
+  print_semihost_syscall( "\tWriting %d bytes to file %d.", n, guest_fd);
+  assert(fd_map[guest_fd].type == SemihostHostFD && "write only supported for host fd");
+  int return_value = write(fd_map[guest_fd].host_fd, buffer, n);
+  print_semihost_syscall("\tDone, wrote %d bytes.", return_value);
+  if (return_value == -1) {
+    guest_errno = errno;
+    return -1;
+  }
+  if (return_value < n) {
+    return n - return_value;
+  }
+  return 0;
+}
+
+int plat_semihost_read_impl(SemihostGuestFD guest_fd, char* buffer, int n)
+{
+  print_semihost_syscall("\tReading %d bytes from file %d.", n, guest_fd);
+  assert(fd_map[guest_fd].type == SemihostHostFD && "read only supported for host fd");
+  int return_value = read(fd_map[guest_fd].host_fd, buffer, n);
+  print_semihost_syscall("\tDone, read %d bytes.", return_value);
+  if (return_value == -1) {
+    guest_errno = errno;
+    return -1;
+  }
+  if (return_value < n) {
+    return n - return_value;
+  }
+  return 0;
+}
+
+int plat_semihost_errno_impl()
+{
+  return guest_errno;
+}
+
+int plat_semihost_seek_impl(SemihostGuestFD guest_fd, int offset)
+{
+  print_semihost_syscall("\tSeeking to %d in file %d.\t", offset, guest_fd);
+  assert(fd_map[guest_fd].type == SemihostHostFD && "seek only supported for host fd");
+  int return_value = lseek(fd_map[guest_fd].host_fd, offset, SEEK_SET);
+  if (return_value == -1) guest_errno = errno;
+  return return_value;
+}
+
+int plat_semihost_close_impl(SemihostGuestFD guest_fd)
+{
+  print_semihost_syscall("\tClosing file handle %d.", guest_fd);
+  assert(fd_map[guest_fd].type == SemihostHostFD && "close only supported for host fd");
+  int host_fd = fd_map[guest_fd].host_fd;
+  deallocate_fd_mapping(guest_fd);
+
+  // do not close standard streams
+  if (host_fd == STDIN_FILENO || host_fd == term_fd || host_fd == term_fd_err) {
+    print_semihost_syscall("\tNot closing host file because it is a sim standard stream.");
+    return 0;
+  }
+
+  int return_value = close(fd_map[guest_fd].host_fd);
+  if (return_value == -1) guest_errno = errno;
+  return return_value;
+}
+
+unsigned long plat_semihost_time_impl(void)
+{
+  time_t current_time = time(NULL);
+  if (current_time == -1) {
+    guest_errno = errno;
+    return 0;
+  }
+  assert(current_time >= 0 && "Negative time returned!");
+  return (unsigned long) current_time;
+}
+
+// returns length of argument string (excluding NULL terminator), -1 on error
+int plat_semihost_get_cmdline_impl(char * arg_buffer, int arg_buffer_len)
+{
+  print_semihost_syscall("Supplying command line args:");
+  if (cmdline_args == NULL) {
+    print_semihost_syscall("\t(Command line args empty)");
+    return 0;
+  }
+  strncpy(arg_buffer, cmdline_args, arg_buffer_len);
+
+  int arg_len;
+  // check if null byte present, if not set manually
+  if (arg_buffer[arg_buffer_len-1]) {
+    arg_buffer[arg_buffer_len-1] = '\0';
+    arg_len =  arg_buffer_len - 1; // also implies string has max length
+  } else
+    arg_len = strnlen(arg_buffer, arg_buffer_len);
+  print_semihost_syscall("\t\"%s\" (length: %d)", arg_buffer, arg_len);
+  return arg_len;
+}
+
+void plat_semihost_args_prepend(char* new_arg)
+{
+  char *old_args = cmdline_args;
+  cmdline_args = strdup(new_arg);
+  if (!old_args) return;
+
+  int new_len = strlen(cmdline_args) + strlen(old_args) + 2;
+  assert((cmdline_args = realloc(cmdline_args, new_len)));
+  strcat(cmdline_args, " ");
+  strcat(cmdline_args, old_args);
+  free(old_args);
+}
