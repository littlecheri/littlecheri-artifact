+#define SEMIHOST_DEBUG_STREAM trace_log
+void print_semihost_syscall(char * specific_format, ...)
+{
+  if (!config_print_semihosting) return;
+
+  va_list args;
+  va_start(args, specific_format);
+  fprintf(SEMIHOST_DEBUG_STREAM, "[Semihost]: ");
+  vfprintf(SEMIHOST_DEBUG_STREAM, specific_format, args);
+  fprintf(SEMIHOST_DEBUG_STREAM, "\n");
+}
+
+void print_semihost_failure(int return_value)
+{
+  print_semihost_syscall("Failure!\n"
+                         "\tReturn value: %d\n"
+                         "\tError code: %s"
+                         , return_value, strerror(errno));
+}
+
+bool semihost_assert_failure_output( void )
+{
+  print_semihost_syscall("Assertion failure!");
+  return false;
+}
+
+inline void semihost_assert(int expression)
+{
+  assert(expression || semihost_assert_failure_output());
+}
+
+#define SEMIHOST_FEATURES_FD 4
+static_assert(STDOUT_FILENO != SEMIHOST_FEATURES_FD, "SEMIHOST_FEATURES_FD clashes with STDOUT_FILENO!");
+static_assert(STDIN_FILENO != SEMIHOST_FEATURES_FD, "SEMIHOST_FEATURES_FD clashes with STDIN_FILENO!");
+static_assert(STDERR_FILENO != SEMIHOST_FEATURES_FD, "SEMIHOST_FEATURES_FD clashes with STDERR_FILENO!");
+
+typedef enum SemihostFDType {
+  SemihostUnusedFD = 0,
+  SemihostHostFD,
+  SemihostStaticFD,
+  SemihostConsoleFD
+} SemihostFDType;
+
+typedef struct SemihostFDMapping {
+  // int guest_fd; guest fd is indexed by 
+  int host_fd;
+  SemihostFDType type;
+} SemihostFDMapping;
+
+// SemihostFDMapping _semihost_features_fd_map = {SEMIHOST_FEATURES_FD, NULL, NULL};
+// SemihostFDMapping _stderr_fd_map = {STDERR_FILENO, STDERR_FILENO, &_semihost_features_fd_map};
+// SemihostFDMapping _stdin_fd_map = {STDERR_FILENO, STDERR_FILENO, &_stderr_fd_map};
+// SemihostFDMapping _stdout_fd_map = {STDOUT_FILENO, STDOUT_FILENO, &_stdin_fd_map};
+
+// statically allocate array for simplicity, refine this when everything else is working
+#define MAX_FD_MAPPINGS 100
+static int fd_mapping_count = 0;
+static SemihostFDMapping fd_map[MAX_FD_MAPPINGS] = { 0 };
+
+static int guest_errno = 0;
+
+SemihostGuestFD allocate_fd_mapping(void) 
+{
+  SemihostGuestFD current_fd = 0;
+  while (current_fd < MAX_FD_MAPPINGS)
+  {
+    if (fd_map[current_fd].type == SemihostUnusedFD) break;
+    current_fd++;
+  }
+  // check we have not exhausted our mappings
+  if (current_fd == MAX_FD_MAPPINGS) return -1;
+  return current_fd;
+}
+
+void deallocate_fd_mapping(SemihostGuestFD guest_fd)
+{
+  assert(fd_map[guest_fd].type != SemihostUnusedFD && "trying to deallocate unmapped fd");
+  fd_map[guest_fd].host_fd = 0;
+  fd_map[guest_fd].type = 0;
+}
+
+SemihostGuestFD allocate_host_fd_mapping(int host_fd)
+{
+  SemihostGuestFD guest_fd = allocate_fd_mapping();
+  assert(guest_fd != -1 && "Exhausted available FD mappings");
+  fd_map[guest_fd].host_fd = host_fd;
+  fd_map[guest_fd].type = SemihostHostFD;
+  return guest_fd;
+}
+
+void plat_semihost_init()
+{
+  allocate_host_fd_mapping(STDIN_FILENO);
+  allocate_host_fd_mapping(term_fd);
+  allocate_host_fd_mapping(term_fd_err);
+}
+
+static int SEMIHOST_OPEN_MODE_MAPPING[12] = {
+  O_RDONLY                              // r
+, O_RDONLY                              // rb
+, O_RDWR                                // r+
+, O_RDWR                                // r+b
+, O_WRONLY | O_CREAT | O_TRUNC          // w
+, O_WRONLY | O_CREAT | O_TRUNC          // wb
+, O_RDWR | O_CREAT | O_TRUNC            // w+
+, O_RDWR | O_CREAT | O_TRUNC            // w+b
+, O_WRONLY | O_CREAT | O_APPEND         // a
+, O_WRONLY | O_CREAT | O_APPEND         // ab
+, O_RDWR | O_CREAT | O_APPEND           // a+
+, O_RDWR | O_CREAT | O_APPEND           // a+b
+};
+
+static char* SEMIHOST_OPEN_MODE_STRING[12] = {
+  "r"
+, "rb"
+, "r+"
+, "r+b"
+, "w"
+, "wb"
+, "w+"
+, "w+b"
+, "a"
+, "ab"
+, "a+"
